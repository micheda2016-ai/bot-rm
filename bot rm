module bot-rm

go 1.21

require (
    github.com/bwmarrin/discordgo v0.27.1
)
package main

import (
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"strings"
	"syscall"

	"github.com/bwmarrin/discordgo"
)

func main() {
	token := os.Getenv("DISCORD_TOKEN")
	dg, _ := discordgo.New("Bot " + token)

	dg.AddHandler(messageCreate)
	dg.AddHandler(onInteraction)

	dg.Open()
	defer dg.Close()

	// Server per Render
	go func() {
		http.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) { fmt.Fprintf(w, "Bot Online") })
		http.ListenAndServe(":"+os.Getenv("PORT"), nil)
	}()

	fmt.Println("Bot attivo e pronto!")
	sc := make(chan os.Signal, 1)
	signal.Notify(sc, syscall.SIGINT, syscall.SIGTERM, os.Interrupt)
	<-sc
}

func messageCreate(s *discordgo.Session, m *discordgo.MessageCreate) {
	if m.Author.ID == s.State.User.ID { return }
	args := strings.Split(m.Content, " ")

	switch args[0] {

	// 1. SETUP TICKET
	case "!setup-ticket":
		msg := &discordgo.MessageSend{
			Embed: &discordgo.MessageEmbed{
				Title:       "🎫 SISTEMA DI ASSISTENZA",
				Description: "Seleziona la categoria per parlare con lo staff:\n\n✉️ **Generale**\n👑 **Piani Alti**\n🛠️ **Supporto Tecnico**",
				Color:       0x3498db,
			},
			Components: []discordgo.MessageComponent{
				discordgo.ActionsRow{
					Components: []discordgo.MessageComponent{
						discordgo.Button{Label: "Generale", Style: discordgo.PrimaryButton, CustomID: "t_gen"},
						discordgo.Button{Label: "Piani Alti", Style: discordgo.DangerButton, CustomID: "t_piani"},
						discordgo.Button{Label: "Supporto", Style: discordgo.SecondaryButton, CustomID: "t_sup"},
					},
				},
			},
		}
		s.ChannelMessageSendComplex(m.ChannelID, msg)

	// 2. PROMOZIONE (!promozione @utente RuoloDa RuoloA Motivo)
	case "!promozione":
		if len(args) < 5 {
			s.ChannelMessageSend(m.ChannelID, "Uso: `!promozione @user Da A Motivo`")
			return
		}
		embed := &discordgo.MessageEmbed{
			Title: "📈 PROMOZIONE AGENTE",
			Description: fmt.Sprintf("**Agente:** %s\n**Da:** %s\n**A:** %s\n**Motivo:** %s", args[1], args[2], args[3], strings.Join(args[4:], " ")),
			Color: 0x2ecc71,
		}
		s.ChannelMessageSendEmbed(m.ChannelID, embed)

	// 3. RETROCESSIONE (!retrocessione @utente RuoloDa RuoloA Motivo)
	case "!retrocessione":
		if len(args) < 5 {
			s.ChannelMessageSend(m.ChannelID, "Uso: `!retrocessione @user Da A Motivo`")
			return
		}
		embed := &discordgo.MessageEmbed{
			Title: "📉 RETROCESSIONE AGENTE",
			Description: fmt.Sprintf("**Agente:** %s\n**Da:** %s\n**A:** %s\n**Motivo:** %s", args[1], args[2], args[3], strings.Join(args[4:], " ")),
			Color: 0xe74c3c,
		}
		s.ChannelMessageSendEmbed(m.ChannelID, embed)

	// 4. CHIAMA FDO
	case "!chiama-fdo":
		s.ChannelMessageDelete(m.ChannelID, m.ID)
		s.ChannelMessageSend(m.ChannelID, "🚨 **FDO RICHIESTE NELLA MAPPA!** 🚨\n@everyone (o tag categoria FDO)")

	// 5. STATS SERVER
	case "!stats":
		guild, _ := s.Guild(m.GuildID)
		s.ChannelMessageSend(m.ChannelID, fmt.Sprintf("📊 **Stats Server:** %d Membri", guild.MemberCount))

	// 6. CREATE CHANNEL
	case "!create-channel":
		if len(args) < 2 { return }
		s.GuildChannelCreate(m.GuildID, args[1], discordgo.ChannelTypeGuildText)
		s.ChannelMessageSend(m.ChannelID, "✅ Canale creato!")
	}
}

// Gestione click bottoni Ticket
func onInteraction(s *discordgo.Session, i *discordgo.InteractionCreate) {
	if i.Type != discordgo.InteractionMessageComponent { return }
	
	s.InteractionRespond(i.Interaction, &discordgo.InteractionResponse{
		Type: discordgo.InteractionResponseChannelMessageWithSource,
		Data: &discordgo.InteractionResponseData{Content: "Ticket in creazione...", Flags: 64},
	})

	ch, _ := s.GuildChannelCreateComplex(i.GuildID, discordgo.GuildChannelCreateData{
		Name: "ticket-" + i.Member.User.Username,
		Type: discordgo.ChannelTypeGuildText,
		PermissionOverwrites: []*discordgo.PermissionOverwrite{
			{ID: i.GuildID, Type: discordgo.PermissionOverwriteTypeRole, Deny: discordgo.PermissionViewChannel},
			{ID: i.Member.User.ID, Type: discordgo.PermissionOverwriteTypeMember, Allow: discordgo.PermissionViewChannel},
		},
	})
	s.ChannelMessageSend(ch.ID, "Benvenuto nel tuo ticket. Uno staffer ti aiuterà a breve.")
}
